{
  "name": "Cheat-Inspector",
  "version": "2.1.0",
  "description": "Программа для обнаружения стороннего ПО.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "icon": "icon.ico",
  "author": "elyrin",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cheat.inspector",
    "productName": "Cheat-Inspector",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  }
}